{
  "name": "security-backend",
  "version": "1.0.0",
  "description": "Node.js + PostgreSQL backend for Security",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node scripts/init-database.js",
    "build": "npm run build:gh-pages",
    "build:gh-pages": "powershell -ExecutionPolicy Bypass -File build.ps1",
    "deploy": "npm run build && gh-pages -d dist",
    "serve": "python -m http.server 8000 || python3 -m http.server 8000",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "nodejs",
    "postgresql",
    "express",
    "api",
    "backend"
  ],
  "author": "Security Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "bootstrap": "^5.3.8",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.4",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
